# Basado en el estándar de Microsoft
BasedOnStyle: Microsoft

# Indentación estándar de Visual Studio (4 espacios)
IndentWidth: 4
TabWidth: 4
UseTab: Never

# DISPOSICIÓN DE LLAVES: Estilo Allman (llaves en línea nueva)
# Este es el cambio más notable respecto a LLVM o Google.
BreakBeforeBraces: Allman

# WRAPPING (Ajuste de líneas):
# En Visual Studio el wrap suele ser visual, no físico. 
# Ponemos 0 para que clang-format NO fuerce saltos de línea por longitud, 
# dejando que sea el editor quien lo maneje visualmente.
ColumnLimit: 0

# ALINEACIÓN DE PUNTEROS: Visual Studio prefiere a la derecha (int *ptr)
PointerAlignment: Right

# OTROS DETALLES DE VS:
BinPackArguments: false
BinPackParameters: false
SpaceBeforeParens: ControlStatements
SpaceBeforeAssignmentOperators: true
SortIncludes: true
